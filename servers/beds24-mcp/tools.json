[
  {
    "name": "beds24_list_bookings",
    "description": "List bookings from Beds24 with optional filters for property, status, and date ranges. Supports pagination.",
    "arguments": [
      {"name": "property_id", "type": "string", "desc": "Filter by property ID"},
      {"name": "status", "type": "string", "desc": "Filter by booking status (e.g., 'confirmed', 'pending')"},
      {"name": "check_in_after", "type": "string", "desc": "Filter bookings with check-in after this date (YYYY-MM-DD)"},
      {"name": "check_in_before", "type": "string", "desc": "Filter bookings with check-in before this date (YYYY-MM-DD)"},
      {"name": "limit", "type": "number", "desc": "Maximum results to return (1-100, default 20)"},
      {"name": "offset", "type": "number", "desc": "Pagination offset (default 0)"},
      {"name": "response_format", "type": "string", "desc": "Output format: 'markdown' or 'json'"}
    ]
  },
  {
    "name": "beds24_get_booking",
    "description": "Get detailed information about a specific booking including guest info, room assignment, and pricing.",
    "arguments": [
      {"name": "booking_id", "type": "string", "desc": "The unique booking ID"},
      {"name": "response_format", "type": "string", "desc": "Output format: 'markdown' or 'json'"}
    ]
  },
  {
    "name": "beds24_create_booking",
    "description": "Create a new booking with guest information, dates, and preferences.",
    "arguments": [
      {"name": "room_id", "type": "number", "desc": "Beds24 room ID to book (required)"},
      {"name": "arrival", "type": "string", "desc": "Arrival/check-in date (YYYY-MM-DD, required)"},
      {"name": "departure", "type": "string", "desc": "Departure/check-out date (YYYY-MM-DD, required)"},
      {"name": "first_name", "type": "string", "desc": "Guest's first name (required)"},
      {"name": "last_name", "type": "string", "desc": "Guest's last name (required)"},
      {"name": "email", "type": "string", "desc": "Guest's email address (required)"},
      {"name": "status", "type": "string", "desc": "Booking status: 'confirmed', 'provisional', etc. (default: confirmed)"},
      {"name": "num_adult", "type": "number", "desc": "Number of adults (default 1)"},
      {"name": "num_child", "type": "number", "desc": "Number of children (default 0)"},
      {"name": "title", "type": "string", "desc": "Guest title: Mr, Mrs, Ms, Dr (optional)"},
      {"name": "phone", "type": "string", "desc": "Guest's phone number (optional)"},
      {"name": "address", "type": "string", "desc": "Guest's street address (optional)"},
      {"name": "city", "type": "string", "desc": "Guest's city (optional)"},
      {"name": "state", "type": "string", "desc": "Guest's state/province (optional)"},
      {"name": "postcode", "type": "string", "desc": "Guest's postcode (optional)"},
      {"name": "country", "type": "string", "desc": "Guest's country (optional)"},
      {"name": "channel", "type": "string", "desc": "Booking channel: 'booking', 'airbnb', 'direct', etc. (optional)"},
      {"name": "unit_id", "type": "number", "desc": "Specific unit ID within the room (optional)"},
      {"name": "price", "type": "number", "desc": "Total booking price override (optional)"},
      {"name": "commission", "type": "number", "desc": "Commission amount (optional)"},
      {"name": "invoice_items", "type": "array", "desc": "Invoice items to attach: [{type, subType, description, qty, amount}] (optional)"},
      {"name": "response_format", "type": "string", "desc": "Output format: 'markdown' or 'json'"}
    ]
  },
  {
    "name": "beds24_update_booking",
    "description": "Update an existing booking's details such as guest info, dates, or status.",
    "arguments": [
      {"name": "booking_id", "type": "string", "desc": "The booking ID to update"},
      {"name": "guest_name", "type": "string", "desc": "Updated guest name"},
      {"name": "guest_email", "type": "string", "desc": "Updated guest email"},
      {"name": "guest_phone", "type": "string", "desc": "Updated guest phone"},
      {"name": "number_of_guests", "type": "number", "desc": "Updated number of guests"},
      {"name": "check_in", "type": "string", "desc": "Updated check-in date"},
      {"name": "check_out", "type": "string", "desc": "Updated check-out date"},
      {"name": "special_requests", "type": "string", "desc": "Updated special requests"},
      {"name": "status", "type": "string", "desc": "Updated booking status"},
      {"name": "invoice_items", "type": "array", "desc": "Invoice items to create or update: [{id?, type?, description?, qty?, amount?, lineTotal?}] — omit id to create new item (type required), include id to update existing"},
      {"name": "response_format", "type": "string", "desc": "Output format: 'markdown' or 'json'"}
    ]
  },
  {
    "name": "beds24_cancel_booking",
    "description": "Cancel an existing booking and optionally record the cancellation reason.",
    "arguments": [
      {"name": "booking_id", "type": "string", "desc": "The booking ID to cancel"},
      {"name": "cancellation_reason", "type": "string", "desc": "Reason for cancellation"},
      {"name": "response_format", "type": "string", "desc": "Output format: 'markdown' or 'json'"}
    ]
  },
  {
    "name": "beds24_delete_booking",
    "description": "Permanently delete a booking from Beds24. This action cannot be undone.",
    "arguments": [
      {"name": "booking_id", "type": "string", "desc": "The booking ID to delete permanently"},
      {"name": "response_format", "type": "string", "desc": "Output format: 'markdown' or 'json'"}
    ]
  },
