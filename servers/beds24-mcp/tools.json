      {"name": "limit", "type": "number", "desc": "Maximum results to return (1-100, default 20)"},
      {"name": "offset", "type": "number", "desc": "Pagination offset (default 0)"},
      {"name": "response_format", "type": "string", "desc": "Output format: 'markdown' or 'json'"}
    ]
  },
