    "arguments": [
      {"name": "property_id", "type": "string", "desc": "The property ID"},
      {"name": "response_format", "type": "string", "desc": "Output format: 'markdown' or 'json'"}
    ]
  },
  {
    "name": "beds24_list_property_rooms",
    "description": "List all rooms for a specific property with details on types, capacities, and amenities.",
    "arguments": [
      {"name": "property_id", "type": "string", "desc": "The property ID to get rooms for"},
      {"name": "room_type", "type": "string", "desc": "Filter by specific room type"},
      {"name": "limit", "type": "number", "desc": "Maximum results to return (1-100, default 50)"},
      {"name": "offset", "type": "number", "desc": "Pagination offset (default 0)"},
      {"name": "response_format", "type": "string", "desc": "Output format: 'markdown' or 'json'"}
    ]
  },
  {
    "name": "beds24_check_availability",
    "description": "Check room availability for specific dates and return available room options with pricing.",
    "arguments": [
      {"name": "property_id", "type": "string", "desc": "The property ID to check (required)"},
      {"name": "start_date", "type": "string", "desc": "Start date of stay (YYYY-MM-DD, required)"},
      {"name": "end_date", "type": "string", "desc": "End date of stay (YYYY-MM-DD, required)"},
      {"name": "room_id", "type": "number", "desc": "Specific room ID to check (optional)"},
      {"name": "response_format", "type": "string", "desc": "Output format: 'markdown' or 'json'"}
    ]
  },
  {
    "name": "beds24_get_calendar",
    "description": "Get calendar values for rooms over a date range including prices, availability, and restrictions.",
    "arguments": [
      {"name": "property_id", "type": "string", "desc": "The property ID (required)"},
      {"name": "start_date", "type": "string", "desc": "Start date for calendar (YYYY-MM-DD, required)"},
      {"name": "end_date", "type": "string", "desc": "End date for calendar (YYYY-MM-DD, required)"},
      {"name": "room_id", "type": "number", "desc": "Specific room ID (optional)"},
      {"name": "include_num_avail", "type": "boolean", "desc": "Include number of available units (default true)"},
      {"name": "include_min_stay", "type": "boolean", "desc": "Include minimum stay restrictions (default true)"},
      {"name": "include_max_stay", "type": "boolean", "desc": "Include maximum stay restrictions (default true)"},
      {"name": "include_multiplier", "type": "boolean", "desc": "Include price multipliers (default true)"},
      {"name": "include_override", "type": "boolean", "desc": "Include price overrides (default true)"},
      {"name": "include_prices", "type": "boolean", "desc": "Include base prices (default true)"},
      {"name": "include_linked_prices", "type": "boolean", "desc": "Include linked/derived prices (default true)"},
      {"name": "include_channels", "type": "boolean", "desc": "Include channel-specific data (default true)"},
      {"name": "response_format", "type": "string", "desc": "Output format: 'markdown' or 'json'"}
    ]
  },
  {
    "name": "beds24_update_calendar",
    "description": "Batch update calendar values for one or more rooms over date ranges (price, availability, stay restrictions, channels).",
    "arguments": [
      {"name": "rooms", "type": "array", "desc": "Array of room updates: [{room_id, calendar: [{from, to, price1?, price2?, min_stay?, max_stay?, num_avail?, override?, channels?}]}]"},
      {"name": "response_format", "type": "string", "desc": "Output format: 'markdown' or 'json'"}
    ]
  },
  {
    "name": "beds24_get_bookings_by_master",
    "description": "Get all bookings in a group by master booking ID. Multi-room bookings are grouped together.",
    "arguments": [
      {"name": "master_id", "type": "string", "desc": "The master booking ID to get all related bookings"},
      {"name": "response_format", "type": "string", "desc": "Output format: 'markdown' or 'json'"}
    ]
  },
  {
    "name": "beds24_setup_from_invite_code",
