      {"name": "invite_code", "type": "string", "desc": "Invite code from Beds24 (https://beds24.com/control3.php?pagetype=apiv2)"},
      {"name": "device_name", "type": "string", "desc": "Device name for the token (default: MCP Server)"}
    ]
  },
  {
    "name": "beds24_check_auth_status",
    "description": "Check the current authentication status including refresh token and access token validity.",
    "arguments": [
      {"name": "response_format", "type": "string", "desc": "Output format: 'markdown' or 'json'"}
    ]
  },
  {
    "name": "beds24_get_pricing_offers",
    "description": "Get pricing offers and special promotions for a date range.",
    "arguments": [
      {"name": "property_id", "type": "string", "desc": "The property ID"},
      {"name": "check_in", "type": "string", "desc": "Check-in date (YYYY-MM-DD)"},
      {"name": "check_out", "type": "string", "desc": "Check-out date (YYYY-MM-DD)"},
      {"name": "number_of_guests", "type": "number", "desc": "Number of guests (default 1)"},
      {"name": "response_format", "type": "string", "desc": "Output format: 'markdown' or 'json'"}
